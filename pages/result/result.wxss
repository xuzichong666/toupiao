.summary-card {
  padding: 32rpx 30rpx;
  background: #ffffff;
  border: 1rpx solid #e6eaf0;
  border-radius: 16rpx;
}

.question-meta,
.meta-left,
.result-header,
.result-footer {
  display: flex;
  align-items: center;
}

.question-meta,
.result-header,
.result-footer {
  justify-content: space-between;
  gap: 20rpx;
}

.meta-left {
  flex-wrap: wrap;
  gap: 10rpx;
}

.status {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 14rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  background: #35c77f;
  border-radius: 8rpx;
}

.status.closed {
  background: #94a3b8;
}

.category-tag {
  color: #0369a1;
  background: #e0f2fe;
}

.more-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 58rpx;
  height: 46rpx;
  color: #697386;
  font-size: 30rpx;
  background: #f1f5f9;
  border-radius: 999rpx;
}

.summary-title {
  display: block;
  margin-top: 20rpx;
  color: #172033;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.3;
}

.summary-creator,
.summary-desc {
  display: block;
  margin-top: 14rpx;
  color: #697386;
  font-size: 26rpx;
  line-height: 1.5;
}

.summary-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 28rpx;
}

.summary-row > view {
  padding: 18rpx 12rpx;
  text-align: center;
  background: #f8fafc;
  border-radius: 12rpx;
}

.summary-number {
  display: block;
  color: #6f63ff;
  font-size: 38rpx;
  font-weight: 800;
}

.summary-label {
  display: block;
  margin-top: 6rpx;
  color: #697386;
  font-size: 23rpx;
}

.deadline {
  display: block;
  margin-top: 22rpx;
  color: #6f63ff;
  font-size: 25rpx;
  font-weight: 700;
  text-align: center;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 26rpx;
}

.result-title {
  display: block;
  text-align: center;
  color: #172033;
  font-size: 30rpx;
  font-weight: 800;
}

.result-item {
  padding: 28rpx;
  background: #ffffff;
  border: 1rpx solid #e6eaf0;
  border-radius: 16rpx;
}

.result-item.top {
  border-color: #8d83ff;
  box-shadow: 0 10rpx 26rpx rgba(111, 99, 255, 0.1);
}

.result-name {
  flex: 1;
  color: #172033;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
}

.result-percent {
  flex: 0 0 auto;
  color: #6f63ff;
  font-size: 32rpx;
  font-weight: 800;
}

.bar {
  height: 16rpx;
  margin: 20rpx 0 14rpx;
  overflow: hidden;
  background: #e6eaf0;
  border-radius: 999rpx;
}

.bar-fill {
  height: 100%;
  background: #6f63ff;
  border-radius: 999rpx;
}

.result-footer {
  color: #697386;
  font-size: 24rpx;
}

.joined-card {
  padding: 26rpx;
  margin-top: 26rpx;
  text-align: center;
  background: #ffffff;
  border: 1rpx solid #e6eaf0;
  border-radius: 16rpx;
}

.joined-title {
  display: block;
  color: #172033;
  font-size: 28rpx;
  font-weight: 800;
}

.joined-desc {
  display: block;
  margin-top: 8rpx;
  color: #697386;
  font-size: 25rpx;
}

.bottom-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 32rpx;
}

.danger-button {
  display: flex;
  grid-column: 1 / -1;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  color: #d92d20;
  font-size: 28rpx;
  font-weight: 600;
  background: #fff1f0;
  border-radius: 12rpx;
}
