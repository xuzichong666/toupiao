.custom-nav {
  background: #ffffff;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
}

.nav-left {
  flex: 0 0 80rpx;
}

.nav-back {
  font-size: 36rpx;
  color: #172033;
}

.nav-title {
  flex: 1;
  text-align: center;
  color: #172033;
  font-size: 34rpx;
  font-weight: 800;
}

.nav-right {
  flex: 0 0 80rpx;
  text-align: right;
}

.nav-cancel {
  color: #697386;
  font-size: 28rpx;
}

.form-section {
  padding: 30rpx;
  margin-bottom: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e6eaf0;
  border-radius: 16rpx;
}

.section-title {
  display: block;
  color: #172033;
  font-size: 30rpx;
  font-weight: 700;
}

.section-row,
.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.section-row {
  align-items: flex-start;
  margin-bottom: 22rpx;
}

.hint,
.counter {
  color: #8992a3;
  font-size: 24rpx;
}

.counter {
  display: block;
  margin-top: 8rpx;
  text-align: right;
}

.field {
  margin-top: 24rpx;
}

.label {
  display: block;
  margin-bottom: 14rpx;
  color: #4b5563;
  font-size: 26rpx;
}

.input,
.textarea,
.option-input {
  width: 100%;
  color: #172033;
  font-size: 28rpx;
  background: #f8fafc;
  border: 1rpx solid #dbe3ee;
  border-radius: 12rpx;
}

.input {
  height: 84rpx;
  padding: 0 22rpx;
}

.textarea {
  min-height: 156rpx;
  padding: 22rpx;
  line-height: 1.45;
}

.segmented {
  display: flex;
  gap: 12rpx;
  padding: 8rpx;
  margin-top: 24rpx;
  background: #f1f5f9;
  border-radius: 14rpx;
}

.segment {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  color: #697386;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 10rpx;
}

.segment.active {
  color: #ffffff;
  background: #6f63ff;
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.option-index {
  flex: 0 0 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  color: #4f46e5;
  font-size: 24rpx;
  font-weight: 700;
  background: #ede9fe;
  border-radius: 50%;
}

.option-input {
  flex: 1;
  height: 76rpx;
  padding: 0 20rpx;
}

.remove-option {
  flex: 0 0 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;
  color: #c2410c;
  font-size: 24rpx;
  background: #fff3ed;
  border-radius: 10rpx;
}

.add-option {
  height: 76rpx;
  margin-top: 22rpx;
}

.option-count-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.option-count-label {
  flex: 0 0 auto;
  color: #697386;
  font-size: 26rpx;
}

.option-count-input {
  flex: 1;
  height: 64rpx;
  padding: 0 16rpx;
  color: #172033;
  font-size: 26rpx;
  background: #f8fafc;
  border: 1rpx solid #dbe3ee;
  border-radius: 10rpx;
  text-align: center;
}

.option-count-btn {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  padding: 0 24rpx;
  color: #ffffff;
  font-size: 24rpx;
  background: #6f63ff;
  border-radius: 10rpx;
}

.setting-row {
  min-height: 92rpx;
  border-top: 1rpx solid #eef2f7;
}

.setting-row > view:first-child {
  flex: 1;
  min-width: 0;
}

.setting-row:first-of-type {
  margin-top: 18rpx;
}

.setting-title {
  display: block;
  color: #172033;
  font-size: 28rpx;
  font-weight: 700;
}

.setting-desc {
  display: block;
  margin-top: 6rpx;
  color: #8992a3;
  font-size: 23rpx;
}

.setting-value {
  flex: 0 0 auto;
  color: #697386;
  font-size: 25rpx;
  text-align: right;
}

.stepper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.stepper button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  color: #6f63ff;
  font-size: 30rpx;
  background: #ede9fe;
  border-radius: 50%;
}

.stepper text {
  min-width: 32rpx;
  text-align: center;
  color: #172033;
  font-size: 28rpx;
  font-weight: 800;
}

.submit-button {
  margin-top: 32rpx;
}
